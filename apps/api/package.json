    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pino": "^7.0.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1"
  }
