{
  "name": "@onbp/api",
  "version": "0.1.0",
  "private": true,
  "description": "Open Node Backend Platform API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
