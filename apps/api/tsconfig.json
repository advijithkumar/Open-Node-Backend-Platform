{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },

  "include": [
    "src/**/*.ts",
    "src/app.ts",
    "src/server.ts"
  ],

  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts"
  ]
}
